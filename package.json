{
  "name": "claude-hud",
  "version": "0.3.0",
  "description": "Real-time statusline HUD for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "commands/",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && c8 --reporter=text --reporter=lcov node --test",
    "test:update-snapshots": "UPDATE_SNAPSHOTS=1 npm test",
    "test:stdin": "npm run build && echo '{\"model\":{\"display_name\":\"Opus\"},\"context_window\":{\"current_usage\":{\"input_tokens\":45000},\"context_window_size\":200000},\"transcript_path\":\"/tmp/test.jsonl\"}' | node dist/index.js",
    "glm:poll": "node src/providers/glm/poller.mjs",
    "glm:poll:once": "node src/providers/glm/poller.mjs --once",
    "minimax:poll": "node src/providers/minimax/poller.mjs",
    "minimax:poll:once": "node src/providers/minimax/poller.mjs --once",
    "alibaba:poll": "node src/providers/alibaba/poller.mjs",
    "alibaba:poll:once": "node src/providers/alibaba/poller.mjs --once",
    "kimi:poll": "node src/providers/kimi/poller.mjs",
    "kimi:poll:once": "node src/providers/kimi/poller.mjs --once"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "hud"
  ],
  "author": "Jarrod Watts",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "c8": "^11.0.0",
    "typescript": "^6.0.3"
  }
}
